# Kaggle Processor Configuration

# Qwen Model (Qwen2.5-14B-Instruct or Qwen2.5-32B-Instruct)
QWEN_MODEL=Qwen/Qwen2.5-14B-Instruct

# Queue file path (update to your Kaggle dataset or Drive path)
QUEUE_FILE=request_queue.json

# Polling interval in seconds
POLL_INTERVAL=30

# Telegram credentials (set via Kaggle Secrets)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
