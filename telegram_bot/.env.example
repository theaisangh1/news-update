# Telegram Bot Configuration
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID for notifications (your user ID or group ID)
# Use @userinfobot to find your chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# GitHub Configuration (for queue sync)
# Create a personal access token at https://github.com/settings/tokens
# Need 'repo' permission
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=yourusername/repo-name

# Queue file path (default: request_queue.json)
QUEUE_FILE=request_queue.json

# Reports directory (default: ../reports)
REPORTS_DIR=../reports
